{
  "name": "aco",
  "version": "0.0.0",
  "description": "aco — TypeScript CLI scaffold (subcommand-capable).",
  "type": "module",
  "bin": {
    "aco": "./dist/cli.js"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "dev:watch": "tsx watch src/cli.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "verify": "pnpm run check && pnpm run typecheck && pnpm run test && pnpm run build",
    "gen:method-map": "node --import tsx/esm scripts/generate-method-map.ts",
    "prepublishOnly": "pnpm run verify"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^12.0.0",
    "commander": "^12.0.0",
    "webdriverio": "^9.27.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^20.0.0",
    "appium-uiautomator2-driver": "^7.5.2",
    "appium-xcuitest-driver": "^11.9.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
