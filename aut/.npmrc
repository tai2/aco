# Expo / React Native tooling (Metro, Babel, autolinking) assumes a flat,
# npm/yarn-style node_modules. pnpm's default isolated linker only exposes
# direct deps at the top level, so transitive packages like babel-preset-expo
# (pulled in by `expo`) are not resolvable by `babel.config.js`. Hoisting makes
# the layout flat and matches Expo's recommended pnpm setup.
node-linker=hoisted
