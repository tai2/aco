{
  "name": "aco-aut",
  "private": true,
  "version": "0.0.0",
  "description": "Example App Under Test for aco e2e testing.",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "prebuild": "expo prebuild --no-install --clean",
