{
  "expo": {
    "name": "aco AUT",
    "slug": "aco-aut",
    "version": "0.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "aco-aut",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "net.tai2.aco.aut"
    },
    "android": {
      "package": "net.tai2.aco.aut",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": ["expo-router"]
  }
}
